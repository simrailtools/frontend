{
  "name": "sit-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "openapi-ts && tsc -b && vite build",
    "preview": "tsc -b && vite build && vite preview",
    "lint": "biome lint",
    "format": "biome check --fix",
    "ci": "biome ci && pnpm run build",
    "generate:api": "openapi-ts",
    "generate:api:local": "cross-env API_BASE_URL=http://localhost:8081 openapi-ts",
    "generate:proto": "buf generate"
  },
